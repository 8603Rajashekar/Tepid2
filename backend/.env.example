# ── Database (Railway provides this automatically via PostgreSQL plugin) ──────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
SYNC_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_MOCK_ENABLED=False

# ── CORS (add your Vercel frontend URL here) ──────────────────────────────────
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ── Notifications (optional — falls back to console if not set) ──────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@company.com
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
PROJECT_NAME=Enterprise Field Operations Platform
VERSION=1.0.0
