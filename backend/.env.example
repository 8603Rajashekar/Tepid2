# ── Database (Azure SQL Database) ──────────────────────────────────────────────
DB_HOST=yourserver.database.windows.net
DB_NAME=yourdatabase
DB_USER=youradmin
DB_PASSWORD=yourpassword
DB_PORT=1433
DB_DRIVER=ODBC Driver 18 for SQL Server

# Optional direct connection URL if you prefer:
# DATABASE_URL=mssql+pyodbc://user:password@yourserver.database.windows.net:1433/yourdb?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no
# SYNC_DATABASE_URL=mssql+pyodbc://user:password@yourserver.database.windows.net:1433/yourdb?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_MOCK_ENABLED=False

# ── CORS (add your Vercel frontend URL here) ──────────────────────────────────
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ── Notifications (optional — falls back to console if not set) ──────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@company.com
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
PROJECT_NAME=Enterprise Field Operations Platform
VERSION=1.0.0
